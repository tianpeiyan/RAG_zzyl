AI_SERVICE_APP_NAME=zzyl-ai-service
AI_SERVICE_APP_ENV=dev
AI_SERVICE_LOG_LEVEL=INFO
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=8000
AI_SERVICE_KNOWLEDGE_BASE_DIR=./knowledge-base
AI_SERVICE_CHROMA_PERSIST_DIR=./data/chroma
AI_SERVICE_BAILIAN_API_KEY=replace-with-api-key
AI_SERVICE_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_SERVICE_BAILIAN_CHAT_MODEL=qwen-plus
AI_SERVICE_BAILIAN_EMBEDDING_MODEL=tongyi-embedding-vision-plus-2026-03-06
AI_SERVICE_BAILIAN_EMBEDDING_DIMENSION=1152
AI_SERVICE_BAILIAN_RERANK_MODEL=qwen3-vl-rerank
AI_SERVICE_BAILIAN_RERANK_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
AI_SERVICE_REQUEST_TIMEOUT_SECONDS=30
AI_SERVICE_REQUEST_MAX_RETRIES=2
AI_SERVICE_REQUEST_RETRY_BACKOFF_SECONDS=0.5
AI_SERVICE_CHUNK_SIZE=800
AI_SERVICE_CHUNK_OVERLAP=120
AI_SERVICE_COLLECTION_NAME=zzyl_knowledge_base_vision_plus
AI_SERVICE_CHAT_HISTORY_DIR=./data/chat_history
AI_SERVICE_EMBEDDING_PROVIDER=dashscope-multimodal
AI_SERVICE_EMBEDDING_BATCH_SIZE=20
AI_SERVICE_LOCAL_EMBEDDING_DIMENSIONS=384
AI_SERVICE_AUTO_RESET_CHROMA_ON_ERROR=true
AI_SERVICE_LLM_FALLBACK_TO_CONTEXT=true
AI_SERVICE_RETRIEVAL_TOP_K=5
AI_SERVICE_RERANK_ENABLED=true
AI_SERVICE_RERANK_CANDIDATE_K=12
AI_SERVICE_RETRIEVAL_MIN_SCORE=0.2
AI_SERVICE_FINAL_CONTEXT_MIN_SCORE=0.34
AI_SERVICE_SHORT_QUERY_FINAL_CONTEXT_MIN_SCORE=0.46
AI_SERVICE_ANSWERABILITY_MIN_SCORE=0.5
AI_SERVICE_QUERY_REWRITE_ENABLED=true
AI_SERVICE_QUERY_REWRITE_LLM_ENABLED=true
AI_SERVICE_INTERNAL_API_KEY=replace-with-internal-key
